# Absolute path to the Design System source repo on your machine.
# Used by the "Edit in Claude Code" button in the viewer Topbar.
# The button opens this path in VS Code (vscode://file/<path>).
#
# Example:
#   NEXT_PUBLIC_DS_REPO_PATH=/Users/you/projects/my-design-system
#
# If unset, the button is shown but disabled.
NEXT_PUBLIC_DS_REPO_PATH=
