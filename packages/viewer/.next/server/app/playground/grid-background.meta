{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/playground/layout,_N_T_/playground/[slug]/layout,_N_T_/playground/[slug]/page,_N_T_/playground/grid-background"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/playground/$d$slug/__PAGE__",
    "/playground/$d$slug",
    "/playground",
    "/_index",
    "/_head"
  ]
}