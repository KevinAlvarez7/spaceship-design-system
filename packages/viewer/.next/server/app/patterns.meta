{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/patterns/layout,_N_T_/patterns/page,_N_T_/patterns"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/patterns/__PAGE__",
    "/patterns",
    "/_index",
    "/_head"
  ]
}