{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/typography/layout,_N_T_/typography/page,_N_T_/typography"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/typography/__PAGE__",
    "/typography",
    "/_index",
    "/_head"
  ]
}