1a:Ta07,<pre class="shiki github-light" style="background-color:#fff;color:#24292e" tabindex="0"><code><span class="line"><span style="color:#D73A49">import</span><span style="color:#24292E"> { ShimmerText, ShimmerDots } </span><span style="color:#D73A49">from</span><span style="color:#032F62"> '@spaceship/design-system'</span><span style="color:#24292E">;</span></span>
<span class="line"></span>
<span class="line"><span style="color:#6A737D">// Default — blob variant, JS-driven radial blobs</span></span>
<span class="line"><span style="color:#24292E">&#x3C;</span><span style="color:#005CC5">ShimmerText</span><span style="color:#24292E">>Thinking&#x3C;/</span><span style="color:#005CC5">ShimmerText</span><span style="color:#24292E">></span></span>
<span class="line"></span>
<span class="line"><span style="color:#6A737D">// Linear — pure CSS rainbow sweep</span></span>
<span class="line"><span style="color:#24292E">&#x3C;</span><span style="color:#005CC5">ShimmerText</span><span style="color:#6F42C1"> variant</span><span style="color:#D73A49">=</span><span style="color:#032F62">"linear"</span><span style="color:#24292E">>Thinking&#x3C;/</span><span style="color:#005CC5">ShimmerText</span><span style="color:#24292E">></span></span>
<span class="line"></span>
<span class="line"><span style="color:#6A737D">// Subtle — secondary→white CSS sweep</span></span>
<span class="line"><span style="color:#24292E">&#x3C;</span><span style="color:#005CC5">ShimmerText</span><span style="color:#6F42C1"> variant</span><span style="color:#D73A49">=</span><span style="color:#032F62">"subtle"</span><span style="color:#24292E">>Thinking&#x3C;/</span><span style="color:#005CC5">ShimmerText</span><span style="color:#24292E">></span></span>
