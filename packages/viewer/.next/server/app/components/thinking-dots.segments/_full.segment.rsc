28:T10de,<pre class="shiki github-light" style="background-color:#fff;color:#24292e" tabindex="0"><code><span class="line"><span style="color:#D73A49">import</span><span style="color:#24292E"> { ThinkingDots } </span><span style="color:#D73A49">from</span><span style="color:#032F62"> '@spaceship/design-system'</span><span style="color:#24292E">;</span></span>
<span class="line"></span>
<span class="line"><span style="color:#6A737D">// Default — diagonal pattern, md size — gravity arcs diagonally, lines curve toward it</span></span>
<span class="line"><span style="color:#24292E">&#x3C;</span><span style="color:#005CC5">ThinkingDots</span><span style="color:#24292E"> /></span></span>
<span class="line"></span>
<span class="line"><span style="color:#6A737D">// Radial ripple, large</span></span>
<span class="line"><span style="color:#24292E">&#x3C;</span><span style="color:#005CC5">ThinkingDots</span><span style="color:#6F42C1"> pattern</span><span style="color:#D73A49">=</span><span style="color:#032F62">"radial"</span><span style="color:#6F42C1"> size</span><span style="color:#D73A49">=</span><span style="color:#032F62">"lg"</span><span style="color:#24292E"> /></span></span>
<span class="line"></span>
<span class="line"><span style="color:#6A737D">// Inline with text</span></span>
<span class="line"><span style="color:#24292E">&#x3C;</span><span style="color:#22863A">span</span><span style="color:#6F42C1"> className</span><span style="color:#D73A49">=</span><span style="color:#032F62">"flex items-center gap-2"</span><span style="color:#24292E">></span></span>
<span class="line"><span style="color:#24292E">  &#x3C;</span><span style="color:#005CC5">ThinkingDots</span><span style="color:#6F42C1"> size</span><span style="color:#D73A49">=</span><span style="color:#032F62">"sm"</span><span style="color:#24292E"> /></span></span>
<span class="line"><span style="color:#24292E">  &#x3C;</span><span style="color:#22863A">span</span><span style="color:#6F42C1"> className</span><span style="color:#D73A49">=</span><span style="color:#032F62">"text-(--text-secondary) [font-size:var(--font-size-sm)]"</span><span style="color:#24292E">></span></span>
<span class="line"><span style="color:#24292E">    Agent is thinking...</span></span>
<span class="line"><span style="color:#24292E">  &#x3C;/</span><span style="color:#22863A">span</span><span style="color:#24292E">></span></span>
<span class="line"><span style="color:#24292E">&#x3C;/</span><span style="color:#22863A">span</span><span style="color:#24292E">></span></span>
<span class="line"></span>
<span class="line"><span style="color:#6A737D">// Slow — gravity arc and spatial rainbow clearly visible</span></span>
<span class="line"><span style="color:#24292E">&#x3C;</span><span style="color:#005CC5">ThinkingDots</span><span style="color:#6F42C1"> duration</span><span style="color:#D73A49">=</span><span style="color:#24292E">{</span><span style="color:#005CC5">3.0</span><span style="color:#24292E">} </span><span style="color:#6F42C1">size</span><span style="color:#D73A49">=</span><span style="color:#032F62">"lg"</span><span style="color:#24292E"> /></span></span>
<span class="line"></span>
<span class="line"><span style="color:#6A737D">// Fast pulse (1.2 s cycle)</span></span>
<span class="line"><span style="color:#24292E">&#x3C;</span><span style="color:#005CC5">ThinkingDots</span><span style="color:#6F42C1"> duration</span><span style="color:#D73A49">=</span><span style="color:#24292E">{</span><span style="color:#005CC5">1.2</span><span style="color:#24292E">} /></span></span>
<span class="line"></span>
<span class="line"><span style="color:#6A737D">// Shadow surface</span></span>
<span class="line"><span style="color:#24292E">&#x3C;</span><span style="color:#005CC5">ThinkingDots</span><span style="color:#6F42C1"> surface</span><span style="color:#D73A49">=</span><span style="color:#032F62">"shadow-border"</span><span style="color:#24292E"> /></span></span>
<span class="line"></span>
<span class="line"><span style="color:#6A737D">// Static — grey dots, straight lines, no animation</span></span>
<span class="line"><span style="color:#24292E">&#x3C;</span><span style="color:#005CC5">ThinkingDots</span><span style="color:#6F42C1"> disableMotion</span><span style="color:#24292E"> /></span></span></code></pre>26:["$","div",null,{"className":"relative rounded-lg border border-zinc-200 overflow-hidden text-sm","children":[["$","div",null,{"className":"flex items-center border-b border-zinc-200 bg-zinc-50 px-4 py-2","children":["$","span",null,{"className":"text-xs text-zinc-400 font-mono","children":"tsx"}]}],["$","div",null,{"className":"overflow-x-auto p-4 bg-white [&>pre]:!bg-transparent [&>pre]:!m-0","dangerouslySetInnerHTML":{"__html":"$28"}}]]}]
